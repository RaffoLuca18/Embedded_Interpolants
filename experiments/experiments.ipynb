   "source": [
    "# Embedded Interpolants\n",
    "\n",
    "Each experiment: **FIT** (learn velocity chain) then **GENERATE** (fresh samples)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Rectangle\n",
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "from src import EmbeddedInterpolants, sliced_wasserstein1, distributions\n",
    "\n",
    "np.random.seed(42)\n",
    "%matplotlib inline\n",
    "plt.rcParams['figure.dpi'] = 130\n",
    "\n",
    "def sw1(X, Y):\n",
    "    X = X.reshape(-1, X.shape[-1]) if X.ndim > 1 else X.reshape(-1,1)\n",
    "    Y = Y.reshape(-1, Y.shape[-1]) if Y.ndim > 1 else Y.reshape(-1,1)\n",
    "    return sliced_wasserstein1(X, Y)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 1. R¹: Gaussian → Bimodal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "FIT:\n",
      "  Bandwidth (quantile, decaying q=0.5->0.1): sigma_init=1.7484\n",
      "  Iter 1: lift_ratio=0.552,  gamma=0.01000,  q=0.500,  sigma=1.748,  M=100\n",
      "  Iter 2: lift_ratio=0.552,  gamma=0.00800,  q=0.420,  sigma=1.423,  M=100\n",
      "  Iter 3: lift_ratio=0.517,  gamma=0.00600,  q=0.340,  sigma=1.114,  M=100\n",
      "  Iter 4: lift_ratio=0.429,  gamma=0.00400,  q=0.260,  sigma=0.828,  M=100\n",
      "  Iter 5: lift_ratio=0.419,  gamma=0.00200,  q=0.180,  sigma=0.560,  M=100\n",
      "  Iter 6: lift_ratio=0.375,  gamma=0.00000,  q=0.100,  sigma=0.307,  M=100\n",
      "\n",
      "TRANSPORT:\n",
      "  Iter 1: lift_ratio=0.567\n",
      "  Iter 2: lift_ratio=0.567\n",
